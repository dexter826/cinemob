rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidMovie() {
      let data = request.resource.data;
      return data.uid == request.auth.uid &&
             data.id != null &&
             data.title is string &&
             data.title.size() > 0 &&
             data.watched_at is timestamp;
    }

    function isValidAlbum() {
      let data = request.resource.data;
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.name.size() > 0 &&
             data.movieDocIds is list;
    }

    // Movies
    match /movies/{movieId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data.uid);
      allow create: if isSignedIn() && isValidMovie();
      allow update: if isSignedIn() && isOwner(resource.data.uid) && isValidMovie();
    }

    // Albums
    match /albums/{albumId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data.uid);
      allow create: if isSignedIn() && isValidAlbum();
      allow update: if isSignedIn() && isOwner(resource.data.uid) && isValidAlbum();
    }

    // Users - stores preferences like previously recommended titles
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Push Subscriptions
    match /push_subscriptions/{userId} {
      allow read, write, delete: if isSignedIn() && isOwner(userId);
    }
  }
}
